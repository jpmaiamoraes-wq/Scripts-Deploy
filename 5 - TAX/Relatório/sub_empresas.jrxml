					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Calibri"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{IE}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="170" y="0" width="90" height="14"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Calibri"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[($F{CNPJ_CPF} .length() == 11) ?
    new com.sankhya.util.StringFormat().format($F{CNPJ_CPF}, "###.###.###-##") :
    new com.sankhya.util.StringFormat().format($F{CNPJ_CPF}, "##.###.###/####-##")]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="30" y="0" width="140" height="14"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
					<bottomPen lineWidth="0.25"/>
					<rightPen lineWidth="0.25"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font fontName="Calibri"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[" " + $F{RAZAO_SOCIAL}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="0" width="30" height="14"/>
				<box>
					<pen lineWidth="0.25"/>
					<topPen lineWidth="0.25"/>
					<leftPen lineWidth="0.25"/>
