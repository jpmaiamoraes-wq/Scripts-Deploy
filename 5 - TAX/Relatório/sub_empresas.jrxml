<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_empresas" language="groovy" pageWidth="555" pageHeight="842" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.771561000000001"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_FORMATO" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    EMP.CODEMP,
    EMP.RAZAOSOCIAL AS RAZAO_SOCIAL,
    EMP.CGC AS CNPJ_CPF,
    EMP.INSCESTAD AS IE,
    EMP.INSCMUN AS IM,
    UFS.UF AS ESTADO,
    CASE
        WHEN PRODUTORRURAL = 'S' THEN 'PRODUTOR RURAL'
        WHEN CODREGTRIB = 1 THEN 'SIMPLES NACIONAL'
        ELSE 'REGIME NORMAL'
    END AS REGIME_TRIBUTACAO
FROM TSIEMP EMP
JOIN TSICID CID ON CID.CODCID = EMP.CODCID
JOIN TSIUFS UFS ON UFS.CODUF = CID.UF
ORDER BY EMP.CODEMP]]>
	</queryString>
	<field name="CODEMP" class="java.lang.String"/>
	<field name="RAZAO_SOCIAL" class="java.lang.String"/>
	<field name="CNPJ_CPF" class="java.lang.String"/>
	<field name="IE" class="java.lang.String"/>
	<field name="IM" class="java.lang.String"/>
	<field name="ESTADO" class="java.lang.String"/>
	<field name="REGIME_TRIBUTACAO" class="java.lang.String"/>
