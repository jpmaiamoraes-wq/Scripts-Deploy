<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_prod" language="groovy" pageWidth="555" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="3.4522712143931047"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="P_FORMATO" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    P.NCM,
    O.OPCAO,
    UFORIG.UF AS UFORIG,
    UFDEST.UF AS UFDEST,
    I.CODRESTRICAO,
    I.CODTRIB,
    I.ALIQUOTA,
    I.REDBASE,
    I.MVASTUFDEST,
    I.MARGLUCROEST,
    P.GRUPOPIS
FROM TGFPRO P
JOIN TGFICM I ON I.CODRESTRICAO IN (P.NCM, P.GRUPOICMS, P.GRUPOICMS2)
JOIN TDDCAM C ON C.NOMETAB = 'TGFICM' AND C.NOMECAMPO = 'TIPRESTRICAO'
JOIN TDDOPC O ON O.NUCAMPO = C.NUCAMPO AND O.VALOR = I.TIPRESTRICAO
JOIN TSIUFS UFORIG ON UFORIG.CODUF = I.UFORIG
JOIN TSIUFS UFDEST ON UFDEST.CODUF = I.UFDEST
WHERE I.TIPRESTRICAO NOT IN ('S','X', 'N')
GROUP BY
    P.NCM, O.OPCAO, I.ALIQUOTA, UFORIG.UF, UFDEST.UF,
    I.CODRESTRICAO, I.CODTRIB, I.REDBASE, I.MVASTUFDEST, I.MARGLUCROEST, P.GRUPOPIS
ORDER BY P.NCM]]>
	</queryString>
